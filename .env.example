CONTAINER_NAME=proxydev
CONTAINER_TIMEZONE=America/Sao_Paulo

# CADDY
CADDY_PORT=80
CADDY_TLS_PORT=443

# MAILTIP
MAILTIP_PORT=1025
MAILTIP_PORT_DASHBOARD=8025

# RESEND
RESEND_API_KEY=key_test_1234567890

# MYSQL
MYSQL_VERSION=8.0.32
MYSQL_DB_PORT=3306
#mysql #host.docker.internal # 127.0.0.1
MYSQL_DB_HOST=127.0.0.1
MYSQL_DATABASE=${CONTAINER_NAME}
MYSQL_USER=${CONTAINER_NAME}
MYSQL_PASSWORD=${CONTAINER_NAME}
MYSQL_ROOT_PASSWORD=root

# POSTGRES
POSTGRES_VERSION=18
POSTGRES_DB_PORT=5432
#postgres #host.docker.internal # 127.0.0.1
POSTGRES_DB_HOST=127.0.0.1
POSTGRES_DB=${CONTAINER_NAME}
POSTGRES_USER=${CONTAINER_NAME}
POSTGRES_PASSWORD=${CONTAINER_NAME}

# REDIS
REDIS_PORT=6379
REDIS_PASSWORD=${CONTAINER_NAME}
REDIS_LOG_PATH=./docker/logs/redis

# RABBITMQ
RABBITMQ_DEFAULT_USER=proxydev
RABBITMQ_DEFAULT_PASS=proxydev
RABBITMQ_PORT=5672
RABBITMQ_TLS_PORT=15672
RABBITMQ_DISK_FREE_LIMIT=2147483648
RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672

# DURABULL
DURABULL_PORT=3030
DURABULL_INTERNAL_PORT=3030
DURABULL_APP_BASE_URL=http://localhost:${DURABULL_PORT}
# Generate with: openssl rand -hex 32
DURABULL_AUTH_SECRET=my-secret
DURABULL_AUTHLESS=false
DURABULL_ENV_CONNECTIONS=true
DURABULL_REDIS_URL_DEV=${REDIS_URL}/0
DURABULL_REDIS_URL_DEV_ENVIRONMENT=development
# IMPORTANT: Do NOT store production credentials here. Use a secrets manager.
# DURABULL_REDIS_URL_PROD=redis://:PASSWORD@HOST:PORT/0
# DURABULL_REDIS_URL_PROD_ENVIRONMENT=production
DURABULL_REDIS_URL_PROD=redis://:pass@localhost:6380/0
DURABULL_REDIS_URL_PROD_ENVIRONMENT=production
DURABULL_REDIS_URL_DEFAULT=DEV
# Generate with: openssl rand -hex 32
DURABULL_REDIS_URL_ENCRYPTION_KEY=

# FIRECRAWL
# Porta pública local (no Dokploy você pode expor via domínio e manter 3002 interno)
FIRECRAWL_PORT=3002
FIRECRAWL_INTERNAL_PORT=3002
FIRECRAWL_EXTRACT_WORKER_PORT=3004
FIRECRAWL_WORKER_PORT=3005

# NuQ Postgres (deve permanecer postgres/postgres/postgres para init mais simples)
FIRECRAWL_POSTGRES_HOST=nuq-postgres
FIRECRAWL_POSTGRES_PORT=5432
FIRECRAWL_POSTGRES_USER=postgres
FIRECRAWL_POSTGRES_PASSWORD=postgres
FIRECRAWL_POSTGRES_DB=postgres

# Segurança
FIRECRAWL_BULL_AUTH_KEY=CHANGEME
FIRECRAWL_USE_DB_AUTHENTICATION=false

# Observabilidade/execução
FIRECRAWL_LOGGING_LEVEL=WARN
FIRECRAWL_NUM_WORKERS_PER_QUEUE=8
FIRECRAWL_CRAWL_CONCURRENT_REQUESTS=10
FIRECRAWL_MAX_CONCURRENT_JOBS=5
FIRECRAWL_BROWSER_POOL_SIZE=5

# IA (escolha um caminho)
# 1) OpenAI compatível (inclui Ollama via /v1)
FIRECRAWL_OPENAI_API_KEY=ollama
FIRECRAWL_OPENAI_BASE_URL=http://host.docker.internal:11434/v1
FIRECRAWL_MODEL_NAME=gemma3:1b
FIRECRAWL_MODEL_EMBEDDING_NAME=embeddinggemma

# 2) Ollama nativo (deixe vazio se usar OPENAI_BASE_URL)
FIRECRAWL_OLLAMA_BASE_URL=

# Proxy opcional
FIRECRAWL_PROXY_SERVER=
FIRECRAWL_PROXY_USERNAME=
FIRECRAWL_PROXY_PASSWORD=
FIRECRAWL_ALLOW_LOCAL_WEBHOOKS=true
FIRECRAWL_BLOCK_MEDIA=false
